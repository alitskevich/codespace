<component id="App">
  <ToastFacility>
    <BrowserService ref="browser" title="@@name" />
    <NavigationService ref="nav" />
    <ItemCollectionFacility>
      <PageRouter (...)="<-nav@route|log:'route'" />
    </ItemCollectionFacility>
  </ToastFacility>
</component>

<component id="Header">
  <header class="header">
    <nav class="inner" role="navigation">
      <a href="/" class="">
        <img class="logo" src="@@assets.logo" alt="logo">
      </a>
      <a href="#/{@link.id}" class="{@link.id==@page?'active':''}" each="link of @@enums.feedsInfo">{@link.title}</a>
      <span class="github">
        <ExternalLink href="https://github.com/nuxt/hackernews" text="Open on GitHub" />
      </span>
    </nav>
  </header>
</component>
<component id="ItemListNav">
  <div class="news-list-nav">
    <NuxtLink to="`/{@feed}/{@page|increment:-1}" disabled="@page|less:1">
      &lt; prev
    </NuxtLink>
    <span class="page">{@page} / {@maxPage}</span>
    <NuxtLink disabled="!@hasMore" to="`/{@feed}/{@page|increment:1}">
      more &gt;
    </NuxtLink>
  </div>
</component>

<component id="Page.News">
  <Header page="@page" />
</component>
<component id="Page.Newest">
  <Header page="@page" />
</component>
<component id="Page.Ask">
  <Header page="@page" />
</component>
<component id="Page.Jobs">
  <Header page="@page" />
</component>
<component id="Page.Show">
  <Header page="@page" />
</component>

<component id="Page.Main">
  <Header page="@page" />
  <div class="view">
    <div class="news-list">
      <div class="spinner" if="@loading">
        <Else>
          <ItemListNav (...)="@params" />
          <ul>
            <PostItem each="item of @@enums.feedsInfo" item="@item" />
          </ul>
          <ItemListNav (...)="@params" />
        </Else>
      </div>
    </div>
  </div>
</component>

<component id="LoadingWrapper">
  <div if="@loading" style="text-align:center">
    <div class="spinner" />
    <Else>
      <Slot />
    </Else>
  </div>
</component>

<component id="PostItem">
  <li class="news-item">
    <span class="score" title="Score">{@item.points}</span>
    <span class="title">
      <Fragment if="@item.url | isAbsolute">
        <a href="@item.url" target="_blank" rel="noopener">{@item.title}</a>
        <span class="host"> ({@item.url|host})</span>
        <Else>
          <NuxtLink to="'/item/' + item.id">{@item.title}</NuxtLink>
        </Else>
      </Fragment>
    </span>
    <br>
    <span class="meta">
      <span if="@item.user" class="by">
        by
        <NuxtLink to="/user/{@item.user}">{@item.user}</NuxtLink>
      </span>
      <span class="time">
        {@item.time|timeAgo} ago
      </span>
      |
      <span if="@item.type !== 'job'" class="comments-link">
        <NuxtLink to="/item/{@item.id}">{@item.comments_count} comment{@item.comments_count|pluralize}</NuxtLink>
      </span>
    </span>
  </li>
</component>

<component id="PostComment">
  <li if="comment && comment.user" class="comment">
    <div class="by">
      <NuxtLink to="'/user/' + comment.user">
        {@comment.user}
      </NuxtLink>
      {@timeAgo(comment.time)} ago
    </div>
    <div class="text" v-html="comment.content" />
    <div if="@comment.comments.length" class="{@open}" class="toggle">
      <a click="open = !open">{@open ? '[-]' : '[+]'} pluralize(comment.comments.length) + ' collapsed'}
      </a>
    </div>
    <ul v-show="open" class="comment-children">
      <PostComment each="childComment in comment.comments" key="childComment.id" comment="childComment" />
    </ul>
  </li>
</component>

<component id="ItemPage">
  <div class="item-view view">
    <div if="!item?.url && !item?.title" class="item-view-header">
      <h1>Page not found</h1>
    </div>
    <component v-else>
      <div class="item-view-header">
        <component if="item.url && isAbsolute(item.url)">
          <a href="item.url" target="_blank" rel="noopener">
            <h1 v-text="item.title" />
          </a>
          <span class="host"> ({@host(item.url)})</span>
        </component>
        <component v-else>
          <h1 v-text="item.title" />
          <div if="item.content" class="content" v-html="item.content" />
        </component>
        <p class="meta">
          {@item.points} points | by
          <NuxtLink to="'/user/' + item.user">
            {@item.user}
          </NuxtLink>
          {@timeAgo(+item.time)} ago
        </p>
      </div>
      <div class="item-view-comments">
        <LoadingWrapper loading="@commentsLoading">
          <p class="item-view-comments-header">
            {@comments ? comments.length + ' comments' : 'No comments yet.'}
          </p>
          <ul class="comment-children">
            <PostComment each="comment in comments" key="comment.id" comment="comment" />
          </ul>
        </LoadingWrapper>
      </div>
    </component>
  </div>
</component>

<component id="UserPage">
  <div class="user-view view">
    <div class="spinner" if="loading" />
    <component v-else-if="user">
      <h1>User: {@user.id}</h1>
      <ul class="meta">
        <li>
          <span class="label">Created:</span> {@timeAgo(new Date(user.created_time))} ago
        </li>
        <li>
          <span class="label">Karma:</span> {@user.karma || '-'}
        </li>
        <li if="user.about" class="about" v-html="user.about" />
      </ul>
      <p class="links">
        <ExternalLink href="'https://news.ycombinator.com/submitted?id=' + user.id" title="submissions" /> |
        <ExternalLink href="'https://news.ycombinator.com/threads?id=' + user.id" title="comments" />
      </p>
    </component>
    <component v-else>
      <h1>User not found.</h1>
    </component>
  </div>
</component>

<component id="ExternalLink">
  <a href="@href" class="{@class}" target="_blank" rel="noopener banner">
    {@text}
  </a>
</component>

<component id="NuxtLink">
  <a href="@to" class="{@class} {@disabled ? 'disabled' : ''}" click="@onClick" if="@disabled">
    <Slot />
  </a>
  <span class="{@class} {@disabled ? 'disabled' : ''}" if="!@disabled">
    <Slot />
  </span>
</component>